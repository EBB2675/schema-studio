{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --config src-tauri/tauri.bundle.conf.json",
    "tauri:build:macos": "tauri build --bundles app,dmg --config src-tauri/tauri.bundle.conf.json",
    "tauri:build:macos:app": "tauri build --bundles app --config src-tauri/tauri.bundle.conf.json",
    "tauri:build:linux": "tauri build --bundles deb --config src-tauri/tauri.bundle.conf.json",
    "tauri:build:linux:portable": "tauri build --bundles deb,appimage --config src-tauri/tauri.bundle.conf.json",
    "backend:build:windows": "python ..\\scripts\\build_light_mode_backend.py",
    "backend:build:macos": "python3 ../scripts/build_light_mode_backend.py",
    "backend:build:linux": "python ../scripts/build_light_mode_backend.py",
    "test": "vitest",
    "test:run": "vitest run",
    "test:contracts": "vitest run tests/contracts.test.ts"
  },
  "dependencies": {
    "axios": "^1.13.1",
    "cytoscape": "^3.33.1",
    "cytoscape-elk": "^2.3.0",
    "elkjs": "^0.11.0",
    "jspdf": "^4.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tauri-apps/cli": "^2.8.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vitest": "^4.0.16"
  }
}
