{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Schema Studio Light",
  "version": "0.1.0",
  "identifier": "org.schemastudio.light",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Schema Studio Light",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon_light.icns",
      "icons/icon_light.ico",
      "icons/icon_light.png"
    ],
    "externalBin": [
      "binaries/schema-studio-backend"
    ],
    "targets": "all"
  }
}
