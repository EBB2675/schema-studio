SCHEMA_UML_REPO_HOST=/absolute/path/to/your/schema-repo
SCHEMA_UML_SECRET=replace-with-a-long-random-string
SCHEMA_UML_PW_SALT=replace-with-a-long-random-string
CADDY_DOMAIN=localhost
VITE_API_BASE=/api
VITE_USE_TASK_API=true
VITE_TASK_POLL_MS=1000
VITE_TASK_POLL_TIMEOUT_MS=180000
SCHEMA_UML_INSTALL_SCHEMA_DEPS=false
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_DEFAULT_QUEUE=schema-uml
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_TIME_LIMIT=300
CELERY_WORKER_CONCURRENCY=2
