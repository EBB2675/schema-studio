# Schema Studio desktop launcher settings for Light Mode development.
# Copy selected values into `.env` if you want the Tauri shell to pick them up automatically.

SCHEMA_STUDIO_DESKTOP_MODE=light
SCHEMA_STUDIO_DESKTOP_HOST=127.0.0.1
SCHEMA_STUDIO_DESKTOP_PORT=5179
SCHEMA_STUDIO_DESKTOP_PYTHON=D:\REPOS\schema-studio\.venv\Scripts\python.exe
SCHEMA_STUDIO_DESKTOP_STARTUP_TIMEOUT_SECONDS=30
SCHEMA_STUDIO_DESKTOP_REUSE_BACKEND=0

# Forwarded to the Python Light Mode backend.
SCHEMA_STUDIO_OPEN_BROWSER=0
SCHEMA_STUDIO_DEFAULT_PACKAGE=nomad_simulations.schema_packages.model_method
SCHEMA_STUDIO_DEFAULT_NAMESPACE=nomad_simulations.schema_packages
UVICORN_LOG_LEVEL=info
